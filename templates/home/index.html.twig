{% extends 'base.html.twig' %}

{% block body %}

    <style>
        :root {
            --navy: #0A1A2F;
            --blue: #1F6FEB;
            --gold: #F2C94C;
            --white: #FFFFFF;
            --red: #D7263D;
            --motion: 0.15s;
        }

        body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Montserrat', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--white);
            position: relative;
            overflow-x: hidden;
            overflow-y: auto;
            background:
                radial-gradient(circle at 20% 15%, rgba(31,111,235,0.38), transparent 45%),
                radial-gradient(circle at 80% 80%, rgba(242,201,76,0.2), transparent 42%),
                linear-gradient(155deg, #061222 0%, var(--navy) 55%, #133765 100%);
        }

        body::before,
        body::after {
            content: '';
            position: fixed;
            pointer-events: none;
            z-index: 0;
        }

        body::before {
            inset: 0;
            background:
                repeating-linear-gradient(
                    90deg,
                    rgba(255,255,255,0.03) 0,
                    rgba(255,255,255,0.03) 2px,
                    transparent 2px,
                    transparent 40px
                );
            opacity: 0.5;
        }

        body::after {
            top: -20%;
            left: 50%;
            width: 70vmax;
            height: 70vmax;
            transform: translateX(-50%);
            background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 62%);
        }

        .home-page {
            position: relative;
            z-index: 1;
            padding: 0.9rem 0.65rem;
        }

        .card-wrapper {
            width: 100%;
            max-width: 28rem;
            margin: 0 auto;
        }

        .card {
            border: 1px solid rgba(242,201,76,0.45);
            border-radius: 1.15rem;
            background:
                linear-gradient(150deg, rgba(10,26,47,0.94) 0%, rgba(13,37,67,0.95) 55%, rgba(31,111,235,0.28) 100%);
            box-shadow:
                0 0 0 1px rgba(255,255,255,0.05) inset,
                0 1rem 2rem rgba(2,8,22,0.42);
            backdrop-filter: blur(3px);
            animation: slideUp var(--motion) ease-out;
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 32%, rgba(255,255,255,0.18) 50%, transparent 68%);
            transform: translateX(-140%);
            animation: crestShine 4.8s ease-in-out infinite;
            pointer-events: none;
        }

        .card::after {
            content: '';
            position: absolute;
            inset: auto 0 0;
            height: 28%;
            background: linear-gradient(to top, rgba(10,26,47,0.65), transparent);
            pointer-events: none;
        }

        @keyframes crestShine {
            0%, 60%, 100% { transform: translateX(-140%); }
            75% { transform: translateX(140%); }
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .card-title {
            font-family: 'Bebas Neue', 'Montserrat', sans-serif;
            letter-spacing: 0.05em;
            font-size: clamp(2rem, 8.4vw, 2.7rem);
            margin: 0 0 0.35rem;
            text-align: center;
            color: var(--white);
            text-shadow: 0 0.35rem 1rem rgba(0,0,0,0.4);
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            width: 100%;
        }

        .card-title::before {
            content: '🛡️';
            font-size: 1.05rem;
            filter: drop-shadow(0 0 0.3rem rgba(242,201,76,0.85));
        }

        .subtitle {
            text-align: center;
            color: rgba(255,255,255,0.76);
            font-size: 0.88rem;
            margin-bottom: 1.25rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.11em;
        }

        .form-group { margin-bottom: 0.95rem; }

        .form-label {
            font-weight: 700;
            color: #dbe7ff;
            font-size: 0.82rem;
            margin-bottom: 0.45rem;
            display: block;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .form-control {
            border-radius: 0.78rem;
            border: 1px solid rgba(242,201,76,0.35);
            background: rgba(255,255,255,0.95);
            color: var(--navy);
            padding: 0.72rem 0.9rem;
            font-size: 0.96rem;
            font-weight: 700;
            transition: border-color var(--motion), box-shadow var(--motion), transform var(--motion);
        }

        .form-control::placeholder {
            color: #7f8aa0;
            font-weight: 500;
        }

        .form-control:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 0.18rem rgba(242,201,76,0.28);
            outline: none;
            transform: translateY(-1px);
        }

        .btn-submit {
            width: 100%;
            border: 0;
            border-radius: 999px;
            padding: 0.78rem 1.2rem;
            margin-top: 1rem;
            color: #092040;
            font-weight: 900;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            background:
                radial-gradient(circle at 28% 22%, rgba(255,255,255,0.65), transparent 35%),
                linear-gradient(132deg, var(--blue) 6%, #4c8cff 45%, var(--gold) 100%);
            box-shadow:
                0 0.3rem 0.7rem rgba(6,16,40,0.42),
                0 -0.2rem 0.5rem rgba(255,255,255,0.23) inset;
            transition: transform var(--motion), box-shadow var(--motion), filter var(--motion);
            position: relative;
        }

        .btn-submit:hover,
        .btn-submit:focus-visible {
            transform: translateY(-2px);
            box-shadow: 0 0.55rem 1.2rem rgba(6,16,40,0.5), 0 -0.2rem 0.5rem rgba(255,255,255,0.2) inset;
            filter: saturate(1.1);
        }

        .btn-submit:active { transform: translateY(0); }

        .alert {
            border-radius: 0.8rem;
            border: 1px solid rgba(215,38,61,0.5);
            background: rgba(215,38,61,0.17);
            color: #ffd6db;
            margin-bottom: 1rem;
            font-weight: 700;
            padding: 0.78rem 0.9rem;
            font-size: 0.9rem;
        }

        .footer-text {
            text-align: center;
            color: rgba(255,255,255,0.7);
            font-size: 0.76rem;
            margin-top: 1.05rem;
            margin-bottom: 0;
            font-weight: 600;
            letter-spacing: 0.04em;
        }

        .autocomplete-wrapper { position: relative; }

        .autocomplete-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 0.35rem);
            left: 0;
            right: 0;
            z-index: 1000;
            max-height: 12.5rem;
            overflow-y: auto;
            border-radius: 0.85rem;
            border: 1px solid rgba(242,201,76,0.45);
            background: #ffffff;
            box-shadow: 0 0.75rem 1.8rem rgba(10,26,47,0.35);
            animation: fadeIn var(--motion) ease-out;
        }

        .autocomplete-dropdown.open { display: block; }

        .autocomplete-item {
            padding: 0.68rem 0.85rem;
            cursor: pointer;
            font-size: 0.93rem;
            font-weight: 700;
            color: #102847;
            border-bottom: 1px solid rgba(10,26,47,0.07);
            transition: background var(--motion), color var(--motion);
        }

        .autocomplete-item:last-child { border-bottom: 0; }

        .autocomplete-item:hover,
        .autocomplete-item.active {
            background: linear-gradient(135deg, rgba(31,111,235,0.12), rgba(242,201,76,0.2));
            color: #0b1f36;
        }

        .autocomplete-empty {
            padding: 0.68rem 0.85rem;
            color: #7f8aa0;
            font-size: 0.9rem;
            text-align: center;
            font-weight: 600;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-4px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (min-width: 576px) {
            .home-page { padding: 1.25rem; }
            .card { border-radius: 1.5rem; }
            .subtitle { font-size: 0.92rem; margin-bottom: 1.6rem; }
            .form-control { font-size: 1rem; padding: 0.8rem 1rem; }
            .footer-text { font-size: 0.82rem; }
        }
    </style>

    <div class="home-page container-fluid d-flex justify-content-center align-items-center" style="min-height: 100vh; padding: 1.25rem 0.75rem;">

        <div class="card-wrapper">
            <div class="card shadow p-4 p-sm-5">

                <h1 class="card-title">
                    Mercato des Agents ⚽
                </h1>

                <p class="subtitle">Connecte-toi au marché du foot</p>

                {% if error %}
                    <div class="alert alert-danger">
                        <strong>Erreur :</strong> {{ error }}
                    </div>
                {% endif %}

                {# Liste des subIds pour l'autocomplete JS #}
                {% set subIdList = [] %}
                {% for user in users|default([]) %}
                    {% set uid = user.fields.subId.stringValue ?? '' %}
                    {% if uid != '' and not (uid starts with 'Arbitre') %}
                        {% set subIdList = subIdList|merge([uid]) %}
                    {% endif %}
                {% endfor %}

                <form method="post" data-turbo="false" novalidate>

                    <div class="form-group">
                        <label class="form-label" for="subId">
                            👤 Nom (SubId)
                        </label>
                        <div class="autocomplete-wrapper">
                            <input type="text" name="subId" id="subId" class="form-control"
                                   autocomplete="off"
                                   placeholder="Ex : Idris"
                                   required>
                            <div class="autocomplete-dropdown" id="subIdDropdown">
                                {% for uid in subIdList|sort %}
                                    <div class="autocomplete-item" data-value="{{ uid }}">{{ uid }}</div>
                                {% endfor %}
                                {% if subIdList is empty %}
                                    <div class="autocomplete-empty">Aucun joueur trouvé</div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="pseudo">
                            🎯 Pseudo
                        </label>
                        <input type="text" name="pseudo" id="pseudo" class="form-control"
                               placeholder="Ton pseudo sur le marché"
                               required>
                    </div>

                    <button type="submit" class="btn btn-submit">
                        ⚡ Valider
                    </button>

                </form>

                <p class="footer-text">
                    🏆 Rejoins la plus grande communauté du foot
                </p>

            </div>
        </div>

    </div>

<script>
(function () {
    const input      = document.getElementById('subId');
    const dropdown   = document.getElementById('subIdDropdown');
    const allItems   = Array.from(dropdown.querySelectorAll('.autocomplete-item'));
    let activeIdx    = -1;

    function openDropdown() {
        dropdown.classList.add('open');
    }

    function closeDropdown() {
        dropdown.classList.remove('open');
        activeIdx = -1;
        allItems.forEach(i => i.classList.remove('active'));
    }

    function filterItems(query) {
        const q = query.trim().toLowerCase();
        let visible = 0;
        allItems.forEach(item => {
            const match = q === '' || item.dataset.value.toLowerCase().includes(q);
            item.style.display = match ? '' : 'none';
            if (match) visible++;
        });

        // Gestion du message "vide"
        let emptyEl = dropdown.querySelector('.autocomplete-empty');
        if (!emptyEl && visible === 0) {
            emptyEl = document.createElement('div');
            emptyEl.className = 'autocomplete-empty';
            emptyEl.textContent = 'Aucun résultat';
            dropdown.appendChild(emptyEl);
        } else if (emptyEl) {
            emptyEl.style.display = visible === 0 ? '' : 'none';
        }
        activeIdx = -1;
        allItems.forEach(i => i.classList.remove('active'));
    }

    function selectItem(item) {
        input.value = item.dataset.value;
        closeDropdown();
        // Focus sur le champ pseudo
        const pseudo = document.getElementById('pseudo');
        if (pseudo) pseudo.focus();
    }

    // Ouvrir au focus
    input.addEventListener('focus', function () {
        filterItems(this.value);
        openDropdown();
    });

    // Filtrer en tapant
    input.addEventListener('input', function () {
        filterItems(this.value);
        openDropdown();
    });

    // Navigation clavier
    input.addEventListener('keydown', function (e) {
        const visible = allItems.filter(i => i.style.display !== 'none');
        if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeIdx = Math.min(activeIdx + 1, visible.length - 1);
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeIdx = Math.max(activeIdx - 1, 0);
        } else if (e.key === 'Enter' && activeIdx >= 0) {
            e.preventDefault();
            selectItem(visible[activeIdx]);
            return;
        } else if (e.key === 'Escape') {
            closeDropdown();
            return;
        } else {
            return;
        }
        allItems.forEach(i => i.classList.remove('active'));
        if (visible[activeIdx]) {
            visible[activeIdx].classList.add('active');
            visible[activeIdx].scrollIntoView({ block: 'nearest' });
        }
    });

    // Clic sur un item
    allItems.forEach(item => {
        item.addEventListener('mousedown', function (e) {
            e.preventDefault(); // empêche le blur de fermer avant le clic
            selectItem(this);
        });
        item.addEventListener('touchend', function (e) {
            e.preventDefault();
            selectItem(this);
        });
    });

    // Fermer si clic ailleurs
    document.addEventListener('mousedown', function (e) {
        if (!input.contains(e.target) && !dropdown.contains(e.target)) {
            closeDropdown();
        }
    });
})();
</script>

{% endblock %}

{% extends 'base.html.twig' %}

{% block body %}

    <style>
        body {
            background: linear-gradient(135deg, #003d99 0%, #0066ff 50%, #004db8 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            position: relative;
            overflow: hidden;
        }

        /* Éléments de fond décoratifs */
        body::before {
            content: '';
            position: fixed;
            top: -50%;
            right: -10%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }

        body::after {
            content: '';
            position: fixed;
            bottom: -20%;
            left: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }

        .home-page {
            position: relative;
            z-index: 1;
        }

        .card-wrapper {
            width: 100%;
            max-width: 450px;
            margin: 0 auto;
        }

        .card {
            background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.98) 100%);
            border: none;
            border-radius: 24px;
            box-shadow:
                0 20px 60px rgba(0, 0, 0, 0.15),
                0 0 1px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);
            animation: slideUp 0.6s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card-title {
            background: linear-gradient(135deg, #003d99 0%, #0066ff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
            font-size: 2.2rem;
            margin-bottom: 1.5rem;
            text-align: center;
            letter-spacing: -1px;
        }

        .subtitle {
            text-align: center;
            color: #6b7280;
            font-size: 0.95rem;
            margin-bottom: 2rem;
            font-weight: 500;
        }

        .form-label {
            font-weight: 600;
            color: #1f2937;
            font-size: 0.95rem;
            margin-bottom: 0.6rem;
            display: block;
        }

        .form-control {
            background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
            border: 2px solid #e5e7eb;
            color: #1f2937;
            border-radius: 12px;
            padding: 0.75rem 1rem;
            font-size: 1rem;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .form-control:focus {
            background: linear-gradient(135deg, #ffffff 0%, #f9fafb 100%);
            border-color: #003d99;
            box-shadow: 0 0 0 3px rgba(0, 61, 153, 0.15);
            color: #1f2937;
            outline: none;
        }

        .form-control::placeholder {
            color: #9ca3af;
            font-weight: 400;
        }

        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, #003d99 0%, #0066ff 100%);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 0.85rem 2rem;
            font-weight: 700;
            font-size: 1rem;
            margin-top: 1.5rem;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            letter-spacing: 0.5px;
        }

        .btn-submit::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn-submit:hover::before {
            width: 300px;
            height: 300px;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 61, 153, 0.4);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        .alert {
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
            color: #991b1b;
            margin-bottom: 1.5rem;
            font-weight: 500;
            padding: 0.9rem 1.2rem;
            animation: slideDown 0.4s ease-out;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .footer-text {
            text-align: center;
            color: #9ca3af;
            font-size: 0.85rem;
            margin-top: 1.5rem;
            font-weight: 500;
        }

        .users-panel {
            margin-top: 1.5rem;
            background: rgba(255, 255, 255, 0.7);
            border-radius: 16px;
            padding: 1rem;
            border: 1px solid rgba(0, 61, 153, 0.08);
        }

        .users-panel h6 {
            color: #003d99;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .users-list {
            max-height: 180px;
            overflow-y: auto;
            margin: 0;
            padding-left: 1.1rem;
        }

        .users-list li {
            color: #1f2937;
            font-size: 0.92rem;
            margin-bottom: 0.35rem;
        }

        .db-status {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            margin-bottom: 1rem;
            padding: 0.45rem 0.8rem;
            border-radius: 999px;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .db-status.connected {
            background: rgba(16, 185, 129, 0.14);
            color: #047857;
        }

        .db-status.disconnected {
            background: rgba(239, 68, 68, 0.14);
            color: #b91c1c;
        }

        /* Animation des inputs */
        .form-control {
            border-radius: 12px;
        }

        /* Responsive */
        @media (max-width: 576px) {
            .card {
                margin: 1rem;
            }

            .card-title {
                font-size: 1.8rem;
            }

            body::before {
                width: 300px;
                height: 300px;
                right: -20%;
            }

            body::after {
                width: 250px;
                height: 250px;
                left: -20%;
            }
        }
    </style>

    <div class="home-page container-fluid d-flex justify-content-center align-items-center" style="min-height: 100vh; padding: 2rem 1rem;">

        <div class="card-wrapper">
            <div class="card shadow p-5">

                <h1 class="card-title">
                    Mercato des Agents ⚽
                </h1>

                <p class="subtitle">Connecte-toi au marché du foot</p>

                {% if error %}
                    <div class="alert alert-danger">
                        <strong>Erreur :</strong> {{ error }}
                    </div>
                {% endif %}

                <form method="post" data-turbo="false" novalidate>

                    <div class="form-group">
                        <label class="form-label" for="subId">
                            👤 Nom (SubId)
                        </label>
                        <input type="text" name="subId" id="subId" class="form-control"
                               placeholder="Ex : Idris"
                               required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="pseudo">
                            🎯 Pseudo
                        </label>
                        <input type="text" name="pseudo" id="pseudo" class="form-control"
                               placeholder="Ton pseudo sur le marché"
                               required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="ville">
                            🏙️ Ville
                        </label>
                        <input type="text" name="ville" id="ville" class="form-control"
                               placeholder="Ex : Paris"
                               required>
                    </div>

                    <button type="submit" class="btn btn-submit">
                        ⚡ Valider
                    </button>

                </form>

                <p class="footer-text">
                    🏆 Rejoins la plus grande communauté du foot
                </p>

            </div>
        </div>

    </div>

{% endblock %}
